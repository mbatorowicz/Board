#!/usr/bin/env bash
# Board — uruchomienie produkcyjne na Linuxie (Docker)
# Użycie: ./board up
#         ADMIN_PASSWORD='haslo' ./board up

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

COMPOSE=()
ENV_FILE="${ROOT}/.env"
DATA_DIR="${ROOT}/data"
USE_SUDO_DOCKER=0

red() { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }

resolve_compose() {
  if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    COMPOSE=(docker compose)
  elif command -v docker-compose >/dev/null 2>&1; then
    COMPOSE=(docker-compose)
  else
    red "Brak Docker Compose. Zainstaluj: sudo apt install -y docker.io docker-compose"
    exit 1
  fi
}

docker_accessible() {
  docker info >/dev/null 2>&1
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    red "Brak Docker. Zainstaluj: sudo apt install -y docker.io docker-compose"
    exit 1
  fi

  resolve_compose

  if docker_accessible; then
    return
  fi

  if [[ "${COMPOSE[0]}" == "docker" ]] && sudo docker info >/dev/null 2>&1; then
    USE_SUDO_DOCKER=1
    COMPOSE=(sudo docker compose)
    yellow "Brak uprawnień do Dockera — używam sudo."
    yellow "Na stałe: sudo usermod -aG docker \$USER && newgrp docker"
    return
  fi

  if [[ "${COMPOSE[0]}" == "docker-compose" ]] && sudo docker-compose version >/dev/null 2>&1; then
    USE_SUDO_DOCKER=1
    COMPOSE=(sudo docker-compose)
    yellow "Brak uprawnień do Dockera — używam sudo."
    yellow "Na stałe: sudo usermod -aG docker \$USER && newgrp docker"
    return
  fi

  red "Docker nie odpowiada. Sprawdź: sudo systemctl start docker"
  exit 1
}

ensure_data_dir() {
  mkdir -p "$DATA_DIR"
  # uid 1001 = użytkownik nextjs w kontenerze
  if [[ ! -O "$DATA_DIR" ]] 2>/dev/null; then
    if [[ "$USE_SUDO_DOCKER" == "1" ]] || [[ "$(id -u)" -eq 0 ]]; then
      chown -R 1001:1001 "$DATA_DIR" 2>/dev/null || sudo chown -R 1001:1001 "$DATA_DIR"
    elif command -v sudo >/dev/null 2>&1; then
      sudo chown -R 1001:1001 "$DATA_DIR" 2>/dev/null || true
    fi
  fi
}

wait_for_http() {
  local port="${BOARD_PORT:-3000}"
  local i
  for i in $(seq 1 30); do
    if curl -sf "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

show_logs_hint() {
  red "Aplikacja nie odpowiada na porcie ${BOARD_PORT:-3000}."
  echo "Ostatnie logi:"
  "${COMPOSE[@]}" logs --tail=40 board 2>/dev/null || "${COMPOSE[@]}" logs --tail=40
  echo ""
  echo "Pełne logi: ./board logs"
}

set_env_value() {
  local key="$1"
  local value="$2"
  local file="$3"
  awk -v k="$key" -v v="$value" '
    BEGIN { found = 0 }
    $0 ~ "^" k "=" { print k "=" v; found = 1; next }
    { print }
    END { if (!found) print k "=" v }
  ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
}

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE" 2>/dev/null || true
    set +a
  fi
}

ensure_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    cp "${ROOT}/.env.example" "$ENV_FILE"
    yellow "Utworzono .env z .env.example"
  fi

  load_env

  if [[ -n "${ADMIN_PASSWORD:-}" ]]; then
    set_env_value "ADMIN_PASSWORD" "$ADMIN_PASSWORD" "$ENV_FILE"
    return
  fi

  current=$(grep -E '^ADMIN_PASSWORD=' "$ENV_FILE" | cut -d= -f2- || true)
  if [[ -n "$current" ]]; then
    return
  fi

  if [[ -t 0 ]]; then
    echo ""
    yellow "Ustaw hasło do panelu /admin (ADMIN_PASSWORD):"
    read -rsp "  Hasło: " input
    echo ""
    if [[ -z "$input" ]]; then
      red "ADMIN_PASSWORD jest wymagane."
      exit 1
    fi
    set_env_value "ADMIN_PASSWORD" "$input" "$ENV_FILE"
    green "Zapisano ADMIN_PASSWORD w .env"
    return
  fi

  red "Brak ADMIN_PASSWORD."
  echo "Uruchom: ADMIN_PASSWORD='twoje-haslo' ./board up"
  exit 1
}

detect_host_ip() {
  hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost"
}

show_status() {
  local ip port
  ip=$(detect_host_ip)
  port="${BOARD_PORT:-3000}"
  echo ""
  green "Board działa."
  echo "  Strona:    http://${ip}:${port}"
  echo "  Admin:     http://${ip}:${port}/admin"
  echo "  Dane:      ${DATA_DIR}/"
  echo ""
  "${COMPOSE[@]}" ps
}

usage() {
  cat <<'EOF'
Board — hostowanie na Linuxie (Docker)

Użycie:
  ./board up          Pierwsze uruchomienie / rebuild i start
  ./board down        Zatrzymaj kontener
  ./board restart     Restart bez rebuildu
  ./board logs        Logi na żywo
  ./board update      git pull + rebuild
  ./board backup      Kopia zapasowa folderu data/
  ./board status      Status kontenera

Pierwsze uruchomienie (jedna komenda):
  ADMIN_PASSWORD='silne-haslo' ./board up

Development (Windows / Linux, bez Dockera):
  npm install && npm run dev

Dokumentacja: docs/
EOF
}

cmd_up() {
  require_docker
  ensure_env
  ensure_data_dir
  yellow "Budowanie i uruchamianie (pierwszy raz może potrwać kilka minut)..."
  "${COMPOSE[@]}" up -d --build
  if wait_for_http; then
    show_status
  else
    show_logs_hint
    exit 1
  fi
}

cmd_down() {
  require_docker
  "${COMPOSE[@]}" down
}

cmd_restart() {
  require_docker
  "${COMPOSE[@]}" restart
  show_status
}

cmd_logs() {
  require_docker
  "${COMPOSE[@]}" logs -f --tail=100 board 2>/dev/null || "${COMPOSE[@]}" logs -f --tail=100
}

cmd_doctor() {
  require_docker
  echo "=== docker ps ==="
  "${COMPOSE[@]}" ps || true
  echo ""
  echo "=== ostatnie logi ==="
  "${COMPOSE[@]}" logs --tail=30 board 2>/dev/null || "${COMPOSE[@]}" logs --tail=30
  echo ""
  echo "=== data/ (uid powinien być 1001) ==="
  ls -la "$DATA_DIR" 2>/dev/null || echo "brak $DATA_DIR"
  echo ""
  if wait_for_http; then
    green "HTTP OK na porcie ${BOARD_PORT:-3000}"
  else
    red "Brak odpowiedzi HTTP na porcie ${BOARD_PORT:-3000}"
  fi
}

cmd_update() {
  require_docker
  if [[ -d "${ROOT}/.git" ]]; then
    git pull --ff-only
  fi
  ensure_env
  "${COMPOSE[@]}" up -d --build
  show_status
}

cmd_backup() {
  ensure_data_dir
  local archive="backup-board-$(date +%Y%m%d-%H%M%S).tar.gz"
  tar -czf "$archive" -C "$ROOT" data/
  green "Kopia: ${ROOT}/${archive}"
}

cmd_status() {
  require_docker
  show_status
}

main() {
  case "${1:-up}" in
    up|start) cmd_up ;;
    down|stop) cmd_down ;;
    restart) cmd_restart ;;
    logs) cmd_logs ;;
    update|pull) cmd_update ;;
    backup) cmd_backup ;;
    status|ps) cmd_status ;;
    doctor) cmd_doctor ;;
    help|-h|--help) usage ;;
    *)
      red "Nieznana komenda: $1"
      usage
      exit 1
      ;;
  esac
}

main "$@"
