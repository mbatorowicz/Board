# Hasło do panelu /admin (wymagane na produkcji)
ADMIN_PASSWORD=

# Nazwa urzędu w nagłówku strony
OFFICE_NAME=Urząd Gminy

# Kanał RSS CERT Polska (domyślny poniżej — zwykle nie trzeba zmieniać)
# CERT_FEED_URL=https://moje.cert.pl/advisory_feed/advisory/feed/

# Odświeżanie feedu CERT w sekundach (domyślnie 1200 = 20 min)
# FEED_REVALIDATE_SECONDS=1200

# Na produkcji za reverse proxy z HTTPS ustaw true (Secure cookies + opcjonalnie HSTS)
# COOKIE_SECURE=true

# Ufaj nagłówkom X-Forwarded-* tylko za reverse proxy (QNAP, nginx)
# TRUST_PROXY=true

# Dozwolone hosty publiczne (przeciw spoofingowi); domyślnie z BOARD_PUBLIC_URL
# ALLOWED_HOSTS=start.urzad.local,192.168.1.50:3000

# Opcjonalnie na słabym QNAP — pomija fetch miniatur linków (od razu placeholder SVG)
LINK_THUMBS=placeholder

# Adres strony dla stacji roboczych (skrypty w deploy/profiles/)
# BOARD_PUBLIC_URL=http://192.168.1.50:3000
