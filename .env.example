# Hasło do panelu /admin (wymagane na produkcji)
ADMIN_PASSWORD=

# Nazwa urzędu w nagłówku strony
OFFICE_NAME=Urząd Gminy

# Opcjonalna allowlista IP (pusta = brak ograniczeń w proxy.ts)
# Na QNAP w LAN często wystarczy puste pole lub zakres sieci urzędu, np. 192.168.1.0/24
ALLOWED_IPS=

# Kanał RSS CERT Polska (domyślny poniżej — zwykle nie trzeba zmieniać)
# CERT_FEED_URL=https://moje.cert.pl/advisory_feed/advisory/feed/

# Odświeżanie feedu CERT w sekundach (domyślnie 1200 = 20 min)
# FEED_REVALIDATE_SECONDS=1200

# Ustaw na true tylko za reverse proxy (nginx), który nadpisuje X-Real-IP.
# Bez tego allowlista IP nie blokuje ruchu (ochrona opiera się na LAN).
# TRUST_PROXY=true
